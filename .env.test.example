# Copy this file to .env.test and fill in values.
# .env.test is gitignored — never commit real credentials.

# Lumio dev server URL (default for local; override in CI)
BASE_URL=http://localhost:3000

# Separate SQLite file for tests — kept isolated from the dev database.
# Path is relative to lumio/ (where Prisma and Next.js run from).
DATABASE_URL=file:./prisma/test.db

# NextAuth secret — any random string works for tests
NEXTAUTH_SECRET=test-secret-do-not-use-in-production
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (only needed for M17 OAuth module)
# In CI, these are mocked — real values needed only for local OAuth tests
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Pre-seeded test user credentials (created by Prisma seed migration)
TEST_USER_EMAIL=test@lumio.dev
TEST_USER_PASSWORD=TestPassword123!
TEST_ADMIN_EMAIL=admin@lumio.dev
TEST_ADMIN_PASSWORD=AdminPassword123!
