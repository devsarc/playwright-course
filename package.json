{
  "name": "playwright-course",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Skills-style Playwright learning platform — build Lumio, write the automation.",
  "scripts": {
    "test": "playwright test",
    "test:watch": "playwright test --watch",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "build:branches": "tsx scripts/build-branches.ts",
    "validate:module": "tsx scripts/validate-module.ts",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
