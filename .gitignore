# Dependencies
node_modules/
lumio/node_modules/

# Playwright output
playwright-report/
test-results/
test-results.json
blob-report/
*.zip

# HAR files contain session cookies and auth tokens — never commit
*.har

# Environment — never commit real secrets
.env.test
.env.local
.env.*.local
lumio/.env
lumio/.env.local

# SQLite database files (created by prisma db push)
lumio/prisma/*.db
lumio/prisma/*.db-journal
lumio/prisma/*.db-shm
lumio/prisma/*.db-wal

# Build artifacts
dist/
lumio/.next/
lumio/out/
lumio/tsconfig.tsbuildinfo
lumio/next-env.d.ts

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Claude Code project config
.claude/

# Auth state files (generated by storageState)
tests/fixtures/auth-state-*.json
tests/**/.auth-state-*.json
